HOST=127.0.0.1
PORT=9621
WEBUI_TITLE='AI Knowledge Lab - LM Studio'
WEBUI_DESCRIPTION='Local Obsidian + LightRAG via LM Studio'

INPUT_DIR=../Obsidian-Test-Vault
WORKING_DIR=./rag_storage_lmstudio
SUMMARY_LANGUAGE=English
ENTITY_EXTRACTION_USE_JSON=true

RERANK_BINDING=null
MAX_PARALLEL_INSERT=1
MAX_ASYNC=1
MAX_TOTAL_TOKENS=16000
MAX_ENTITY_TOKENS=4000
MAX_RELATION_TOKENS=5000
CHUNK_SIZE=800
CHUNK_OVERLAP_SIZE=100

LLM_BINDING=openai
LLM_BINDING_HOST=http://127.0.0.1:1234/v1
LLM_BINDING_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3-14b

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://127.0.0.1:1234/v1
EMBEDDING_BINDING_API_KEY=lm-studio
EMBEDDING_MODEL=nomic-embed
EMBEDDING_DIM=768
EMBEDDING_TOKEN_LIMIT=8192

LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
